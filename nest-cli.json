{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      "infrastructure/email/templates/**/*",
      "infrastructure/i18n/translations/**/*"
    ],
    "watchAssets": true
  }
}
